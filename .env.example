# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used by getStaticProps and Next API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# On-demand ISR revalidation (same value in both; generate with `openssl rand -hex 24`)
REVALIDATE_SECRET=change-me
NEXT_PUBLIC_REVALIDATE_SECRET=change-me

# Canonical site origin (SEO, sitemaps)
NEXT_PUBLIC_SITE_URL=https://deepskills.pk

# Optional
# NEXT_PUBLIC_GSC_VERIFICATION=google-search-console-token
# NEXT_PUBLIC_EMAIL_ENDPOINT=/api/admission-email.php
# CRON_SECRET=change-me
